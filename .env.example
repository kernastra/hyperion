# Path to the yt-dlp executable. Defaults to "yt-dlp" (resolved on PATH) if unset.
YTDLP_PATH=yt-dlp

# Path to the ffmpeg executable. Defaults to "ffmpeg" (resolved on PATH) if unset.
FFMPEG_PATH=ffmpeg

# Optional. If set, all /api/* routes require a matching
# `Authorization: Bearer <token>` (or `x-hyperion-token`) header, else they
# return 401. If unset, /api/* is open (fine for local use behind
# Caddy + Tailscale). When set, your reverse proxy must inject the header.
HYPERION_AUTH_TOKEN=
