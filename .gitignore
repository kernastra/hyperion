# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python virtual environment
.venv/
venv/
__pycache__/
*.py[cod]
*$py.class

# Downloaded files and output
downloads/*
!downloads/.gitkeep
*.mp4
*.mp3
*.webm
*.mkv
*.avi
*.mov
*.wmv
*.flv
*.m4v
*.m4a
*.opus
*.flac
*.wav
*.aac
*.ogg
*.part
*.ytdl
*.temp

# Application data (sensitive / machine-specific)
hyperion.config.json
cookies.txt
cookies-*.txt
history.json
download-history.json

# IDE files
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs
*.log

# Temporary folders
tmp/
temp/

# Turborepo
.turbo

# Sentry Config File
.sentryclirc
